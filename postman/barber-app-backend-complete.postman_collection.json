  "item": [
    {
      "name": "🔐 AUTHENTICATION",
      "description": "Endpoints de autenticação do barbeiro",
      "item": [
        {
          "name": "Register Barber",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - Barbeiro registrado', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('barberId', String(json.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Barbeiro\",\n  \"email\": \"joao@barbearia.com\",\n  \"password\": \"Senha123!\",\n  \"phone\": \"+5511987654321\",\n  \"avatar_url\": \"https://example.com/avatar.jpg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Registrar um novo barbeiro na plataforma.\n\n**Validações:**\n- name: obrigatório\n- email: válido e único\n- password: 6-20 caracteres\n- phone: formato brasileiro válido\n- avatar_url: opcional"
          }
        },
        {
          "name": "Login Barber",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Login bem-sucedido', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('accessToken', json.access_token);",
                  "    console.log('✅ Token salvo: ' + json.access_token.substring(0, 20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao@barbearia.com\",\n  \"password\": \"Senha123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Fazer login do barbeiro. Retorna JWT válido por 7 dias.\n\nO token é automaticamente salvo na variável `accessToken` para uso em requisições autenticadas."
          }
        },
        {
          "name": "Get Profile (Autenticado)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "profile"]
            },
            "description": "Obter dados do perfil do barbeiro autenticado.\n\n**Requer:** JWT válido no header Authorization"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"Senha123!\",\n  \"new_password\": \"NovaSenha456!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "change-password"]
            },
            "description": "Alterar senha do barbeiro autenticado.\n\n**Requer:** JWT válido e senha atual correta"
          }
        }
      ]
    },
